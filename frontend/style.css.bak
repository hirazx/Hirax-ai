* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
    background: #0a0a0f;
    color: #e0e0e0;
    height: 100vh;
    overflow: hidden;
}

.app {
    display: flex;
    height: 100vh;
    background: #0a0a0f;
}

/* Sidebar */
.sidebar {
    width: 240px;
    background: #14141a;
    border-right: 1px solid #2a2a33;
    display: flex;
    flex-direction: column;
    padding: 20px;
}

.sidebar-header {
    margin-bottom: 30px;
}

.sidebar-header h2 {
    font-size: 20px;
    color: #00d4ff;
    margin-bottom: 8px;
}

.mode-badge {
    font-size: 12px;
    background: #1a3a4a;
    color: #00d4ff;
    padding: 4px 12px;
    border-radius: 12px;
    display: inline-block;
}

.sidebar-menu {
    flex: 1;
}

.sidebar-menu button {
    width: 100%;
    padding: 12px 16px;
    margin-bottom: 8px;
    background: transparent;
    color: #c0c0c0;
    border: 1px solid #2a2a33;
    border-radius: 8px;
    cursor: pointer;
    font-size: 14px;
    transition: all 0.3s;
    text-align: left;
}

.sidebar-menu button:hover {
    background: #1a1a24;
    border-color: #00d4ff;
    color: #00d4ff;
}

.sidebar-footer {
    margin-top: auto;
    padding-top: 20px;
    border-top: 1px solid #2a2a33;
    font-size: 13px;
}

.status {
    color: #00ff88;
}

/* Main Chat */
.main {
    flex: 1;
    display: flex;
    flex-direction: column;
    background: #0f0f15;
}

.chat-header {
    padding: 16px 24px;
    border-bottom: 1px solid #2a2a33;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: #14141a;
}

.chat-header h3 {
    font-size: 16px;
    font-weight: 400;
}

.upload-btn {
    background: #1a2a3a;
    padding: 6px 16px;
    border-radius: 20px;
    cursor: pointer;
    font-size: 14px;
    transition: background 0.3s;
}

.upload-btn:hover {
    background: #2a3a4a;
}

.chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 20px 24px;
}

.message {
    display: flex;
    margin-bottom: 20px;
    gap: 12px;
    animation: slideIn 0.3s ease;
}

.message .avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #1a2a3a;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    flex-shrink: 0;
}

.message .content {
    flex: 1;
    line-height: 1.6;
}

.message .content p {
    margin-bottom: 8px;
}

.message .content code {
    background: #1a1a24;
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 13px;
}

.message .content pre {
    background: #14141a;
    padding: 16px;
    border-radius: 8px;
    overflow-x: auto;
    margin: 8px 0;
    border: 1px solid #2a2a33;
}

.message.bot .content {
    color: #e0e0e0;
}

.message.user .content {
    color: #00d4ff;
}

.message.user {
    flex-direction: row-reverse;
}

/* Chat Input */
.chat-input {
    padding: 16px 24px;
    border-top: 1px solid #2a2a33;
    background: #14141a;
}

.chat-input textarea {
    width: 100%;
    padding: 12px;
    background: #0a0a0f;
    color: #e0e0e0;
    border: 1px solid #2a2a33;
    border-radius: 8px;
    resize: vertical;
    font-family: inherit;
    font-size: 14px;
}

.chat-input textarea:focus {
    outline: none;
    border-color: #00d4ff;
}

.input-actions {
    display: flex;
    gap: 10px;
    margin-top: 10px;
}

.input-actions button {
    padding: 8px 24px;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-size: 14px;
    transition: all 0.3s;
}

#sendBtn {
    background: #00d4ff;
    color: #0a0a0f;
    font-weight: 600;
}

#sendBtn:hover {
    background: #00b8e6;
    transform: scale(1.02);
}

#clearBtn {
    background: #2a2a33;
    color: #c0c0c0;
}

#clearBtn:hover {
    background: #3a3a44;
}

/* Terminal Panel */
.terminal-panel {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    height: 50vh;
    background: #0a0a0f;
    border-top: 1px solid #2a2a33;
    z-index: 1000;
}

.terminal-header {
    display: flex;
    justify-content: space-between;
    padding: 8px 16px;
    background: #14141a;
    border-bottom: 1px solid #2a2a33;
}

.terminal-header button {
    background: none;
    border: none;
    color: #c0c0c0;
    cursor: pointer;
    font-size: 18px;
}

#terminal {
    height: calc(100% - 40px);
    padding: 8px;
    overflow-y: auto;
    font-family: 'Courier New', monospace;
    font-size: 13px;
    color: #00ff88;
}

/* Animations */
@keyframes slideIn {
    from {
        opacity: 0;
        transform: translateY(-10px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

/* Scrollbar */
::-webkit-scrollbar {
    width: 8px;
    height: 8px;
}

::-webkit-scrollbar-track {
    background: #0a0a0f;
}

::-webkit-scrollbar-thumb {
    background: #2a2a33;
    border-radius: 4px;
}

::-webkit-scrollbar-thumb:hover {
    background: #3a3a44;
}

/* Responsive */
@media (max-width: 768px) {
    .sidebar {
        display: none;
    }
}